{
  "env": {
    "TZ": "America/Los_Angeles",
    "MCP_TIMEOUT": "60000",
    "ENABLE_TOOL_SEARCH": "auto",
    "MGREP_MAX_FILE_COUNT": "2000",
    "CLAUDE_CODE_NO_FLICKER": "0",
    "CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "ECC_ENABLE_INSAITS": "0",
    "ECC_QUALITY_GATE_FIX": "true",
    "ECC_QUALITY_GATE_STRICT": "true",
    "ECC_DISABLED_HOOKS": "stop:desktop-notify",
    "ECC_HOOK_PROFILE": "standard",
    "COGFS_SELF": "agent_lindong",
    "COGFS_NAMESPACE": "default"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Write",
      "Edit",
      "MultiEdit",
      "Read",
      "Grep",
      "Glob",
      "LS",
      "Skill",
      "Task",
      "WebSearch",
      "WebFetch",
      "Monitor",
      "mcp__weixin-reader__*",
      "mcp__web-search-prime__*",
      "mcp__web-reader__*",
      "mcp__zai-mcp-server__*",
      "mcp__zread__*",
      "mcp__feishu-mcp__*",
      "mcp__github__*",
      "mcp__sequential-thinking__*",
      "mcp__context7__*",
      "mcp__devfleet__*",
      "mcp__playwright__*",
      "mcp__chrome-devtools__*",
      "mcp__memory__*",
      "mcp__prompts.chat__*",
      "mcp__mcp-search__*",
      "mcp__plugin_claude-mem_mcp-search__*",
      "mcp__plugin_prompts_chat_prompts_chat__*",
      "mcp__plugin_everything-claude-code_*",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(*codeagent-wrapper*)",
      "Bash(~/.claude/bin/codeagent-wrapper --backend gemini*)",
      "Bash(~/.claude/bin/codeagent-wrapper --backend codex*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/ask-recommend-gate.js\"",
            "timeout": 28
          }
        ],
        "description": "Gate AskUserQuestion: block (exit 2) when options lack a clearly-marked recommendation + reason; agent must re-issue with both. Tiered LLM judge (GLM → Anthropic API → claude -p subscription; see hooks/lib/llm-judge.js) reads tool_input.questions directly; fail-open on no-backend/error/timeout. Enforces CLAUDE.md 'Surface Choices (Real Ones), Recommend One'.",
        "id": "pre:ask-user-question:recommend-gate"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/desktop-notify.js\"",
            "timeout": 6
          }
        ],
        "description": "Desktop notification when Claude finishes responding: Ghostty OSC9 (clicking focuses the originating tab) with terminal-notifier as fallback elsewhere. Replaces the ECC plugin's stop:desktop-notify (disabled via ECC_DISABLED_HOOKS) so the logic lives in version control, not a third-party plugin cache.",
        "id": "stop:desktop-notify-local"
      }
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "editorMode": "vim",
  "teammateMode": "tmux",
  "remoteControlAtStartup": true
}
