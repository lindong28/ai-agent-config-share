{
  "env": {
    "TZ": "America/Los_Angeles",
    "MCP_TIMEOUT": "60000",
    "ENABLE_TOOL_SEARCH": "auto",
    "MGREP_MAX_FILE_COUNT": "2000",
    "CLAUDE_CODE_NO_FLICKER": "0",
    "CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "ECC_ENABLE_INSAITS": "0",
    "ECC_QUALITY_GATE_FIX": "true",
    "ECC_QUALITY_GATE_STRICT": "true",
    "ECC_DISABLED_HOOKS": "",
    "ECC_HOOK_PROFILE": "standard",
    "COGFS_SELF": "agent_lindong",
    "COGFS_NAMESPACE": "default"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Write",
      "Edit",
      "MultiEdit",
      "Read",
      "Grep",
      "Glob",
      "LS",
      "Skill",
      "Task",
      "WebSearch",
      "WebFetch",
      "mcp__weixin-reader__*",
      "mcp__web-search-prime__*",
      "mcp__web-reader__*",
      "mcp__zai-mcp-server__*",
      "mcp__zread__*",
      "mcp__feishu-mcp__*",
      "mcp__github__*",
      "mcp__sequential-thinking__*",
      "mcp__context7__*",
      "mcp__devfleet__*",
      "mcp__playwright__*",
      "mcp__chrome-devtools__*",
      "mcp__memory__*",
      "mcp__prompts.chat__*",
      "mcp__mcp-search__*",
      "mcp__plugin_claude-mem_mcp-search__*",
      "mcp__plugin_prompts_chat_prompts_chat__*",
      "mcp__plugin_everything-claude-code_*",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(*codeagent-wrapper*)",
      "Bash(~/.claude/bin/codeagent-wrapper --backend gemini*)",
      "Bash(~/.claude/bin/codeagent-wrapper --backend codex*)"
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "editorMode": "vim",
  "teammateMode": "tmux",
  "remoteControlAtStartup": true
}
